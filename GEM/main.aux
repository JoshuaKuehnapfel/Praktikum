\newlabel{tab:gain_fit_parameter}{{1}{4}{Fitparameter des exponentiellen Fits $G(U)=a\,e^{bU}$ für den Gain in Abhängigkeit der Spannung für verschiedene Gasgemische}{table.1}{}}
