\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Gain in Abhängigkeit von der angelegten Spannung $V_{Drift}$ bei einer Gasmischung von 70\% Ar und 30\% $\text  {CO}_2$. Der gelbe Bereich zeigt die möglichen Exponentialfunktionen mit den Parametern $\pm 1 \sigma $, wobei Korrelationen zwischen den Fitparametern berücksichtigt wurden.}}{6}{figure.3}\protected@file@percent }
\newlabel{fig:7030Vdrift}{{3}{6}{Gain in Abhängigkeit von der angelegten Spannung $V_{Drift}$ bei einer Gasmischung von 70\% Ar und 30\% $\text {CO}_2$. Der gelbe Bereich zeigt die möglichen Exponentialfunktionen mit den Parametern $\pm 1 \sigma $, wobei Korrelationen zwischen den Fitparametern berücksichtigt wurden}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Einfluss der Gasmischungen auf den Gain. Bei dem Plot wurden die unteren 3 Messpunkte von der 60/40-Mischung weggelassen, da es praktisch keine Verstärkung gab und ein exponentieller Fit mit diesen Daten auch deshalb nicht sinnvoll wäre. Der Fit an die Daten ist der gleich wie weiter oben. Die Parameter der Fits und die Güte der Anpassungen sind in Tabelle \ref {tab:gain_fit_parameter} aufgelistet.}}{7}{figure.4}\protected@file@percent }
\newlabel{fig:Vdriftalle}{{4}{7}{Einfluss der Gasmischungen auf den Gain. Bei dem Plot wurden die unteren 3 Messpunkte von der 60/40-Mischung weggelassen, da es praktisch keine Verstärkung gab und ein exponentieller Fit mit diesen Daten auch deshalb nicht sinnvoll wäre. Der Fit an die Daten ist der gleich wie weiter oben. Die Parameter der Fits und die Güte der Anpassungen sind in Tabelle \ref {tab:gain_fit_parameter} aufgelistet}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Einfluss der Gasmsichung auf den Gain. Die Datenpunkte bei 3250 V wurden aus den vorherigen Fits extrapoliert. }}{7}{figure.5}\protected@file@percent }
\newlabel{fig:Vergleich_Gemisch}{{5}{7}{Einfluss der Gasmsichung auf den Gain. Die Datenpunkte bei 3250 V wurden aus den vorherigen Fits extrapoliert}{figure.5}{}}
